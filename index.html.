<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brandvalley — Performance UGC Marketplace UK</title>
    
    <meta name="description" content="Brandvalley: The UK's first performance-only UGC marketplace. Brands pay per view, creators earn per view.">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=DM+Sans:wght@400;500;700&family=Syne:wght@800&display=swap" rel="stylesheet">

    <style>
        :root {
            --ink: #0a0a0f;
            --ink-soft: #3a3a4a;
            --cream: #f8f6f2; 
            --gold: #c9a84c;
            --purple: #1e1060; 
            --white: #ffffff;
            --border: rgba(10,10,15,0.08);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--ink);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3 {
            font-family: 'Libre Baskerville', serif;
            letter-spacing: -0.01em;
        }

        nav {
            position: fixed; top: 0; width: 100%; z-index: 100;
            padding: 0 40px;
            display: flex; align-items: center; justify-content: space-between;
            height: 72px;
            transition: all 0.3s ease;
        }
        nav.scrolled {
            background: rgba(248, 246, 242, 0.95);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border);
            height: 64px;
        }
        .nav-logo {
            font-family: 'Syne', sans-serif;
            font-size: 1.4rem; font-weight: 800;
            color: var(--ink); text-decoration: none;
        }
        .nav-logo span { color: var(--gold); }
        
        .nav-btn-solid { 
            background: var(--purple); 
            color: var(--white); 
            font-size: 13px; 
            font-weight: 700;
            padding: 10px 20px; 
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.2s;
        }

        .hero {
            padding: 160px 24px 80px;
            text-align: center;
            max-width: 900px; margin: 0 auto;
        }
        .hero h1 {
            font-size: clamp(2.5rem, 6vw, 4.2rem);
            line-height: 1.1; margin-bottom: 24px; color: var(--purple);
        }
        .hero h1 em { font-style: italic; font-weight: 400; color: var(--gold); }

        .waitlist-box {
            max-width: 480px; margin: 0 auto 100px;
            background: var(--white); padding: 40px;
            border-radius: 16px; border: 1px solid var(--border);
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        .how-tabs {
            display: flex; justify-content: center; margin-bottom: 30px;
            background: var(--cream); padding: 4px; border-radius: 10px;
        }
        .how-tab {
            flex: 1; text-align: center; padding: 12px; 
            cursor: pointer; font-weight: 700; font-size: 14px;
            border-radius: 8px; transition: 0.3s; color: var(--ink-soft);
        }
        .how-tab.active { background: var(--white); color: var(--purple); box-shadow: 0 2px 8px rgba(0,0,0,0.05); }

        .form-field { margin-bottom: 20px; }
        .form-field label { display: block; font-size: 13px; font-weight: 700; margin-bottom: 6px; }
        .form-field input {
            width: 100%; padding: 14px; border: 1px solid var(--border); 
            border-radius: 8px; font-family: 'DM Sans', sans-serif; outline-color: var(--purple);
        }
        .submit-btn {
            width: 100%; padding: 16px; background: var(--purple);
            color: var(--white); border: none; border-radius: 8px;
            font-weight: 700; cursor: pointer; font-size: 16px; transition: 0.2s;
        }
        .submit-btn:hover { background: #2d1f6e; transform: translateY(-1px); }

        .hidden { display: none !important; }

        @media (max-width: 600px) {
            nav { padding: 0 20px; }
            .waitlist-box { padding: 30px 20px; }
        }
    </style>
</head>
<body>

<nav id="navbar">
    <a class="nav-logo" href="#">Brand<span>valley</span></a>
    <a href="#waitlist" class="nav-btn-solid">Get Early Access</a>
</nav>

<section class="hero">
    <h1>The smarter way to run <em>influencer marketing</em></h1>
    <p style="color: var(--ink-soft); margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">
        Brandvalley is the UK's first performance-only marketplace. Brands pay for results, creators earn for views. No flat fees. No gatekeeping.
    </p>
</section>

<section id="waitlist">
    <div class="waitlist-box">
        <h3 style="margin-bottom: 25px; text-align: center;">Join the Brandvalley Waitlist</h3>
        
        <form id="signup-form">
            <div class="how-tabs">
                <input type="radio" name="role" id="role-brand" value="brand" checked style="display:none;">
                <div class="how-tab active" id="tab-brand" onclick="setRole('brand')">I'm a Brand</div>
                
                <input type="radio" name="role" id="role-creator" value="creator" style="display:none;">
                <div class="how-tab" id="tab-creator" onclick="setRole('creator')">I'm a Creator</div>
            </div>

            <div class="form-field">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" placeholder="Your name" required>
            </div>

            <div class="form-field">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required>
            </div>

            <div class="form-field" id="company-field">
                <label for="company">Brand / Company Name</label>
                <input type="text" id="company" name="company" placeholder="e.g. Brandvalley Ltd" required>
            </div>

            <button type="submit" class="submit-btn" id="submit-btn">Secure My Spot →</button>
        </form>

        <div id="thank-you" class="hidden" style="text-align: center; padding: 20px 0;">
            <div style="font-size: 40px; margin-bottom: 10px;">🎉</div>
            <h3>You're on the list!</h3>
            <p style="font-size: 14px; color: var(--ink-soft); margin-top: 10px;">
                Welcome to Brandvalley. We'll be in touch regarding your invitation shortly.
            </p>
        </div>
    </div>
</section>

<script>
    // 1. Scroll-sensitive Navigation
    window.addEventListener('scroll', () => {
        document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 20);
    });

    // 2. Interactive Role Switcher
    function setRole(role) {
        document.getElementById('role-' + role).checked = true;
        
        document.getElementById('tab-brand').classList.remove('active');
        document.getElementById('tab-creator').classList.remove('active');
        document.getElementById('tab-' + role).classList.add('active');

        const field = document.getElementById('company-field');
        const input = document.getElementById('company');
        
        if (role === 'brand') {
            field.classList.remove('hidden');
            input.setAttribute('required', 'required');
        } else {
            field.classList.add('hidden');
            input.removeAttribute('required');
            input.value = ''; 
        }
    }

    // 3. Form Submission Logic
    document.getElementById('signup-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = document.getElementById('submit-btn');
        const form = this;
        
        btn.textContent = 'Registering...';
        btn.disabled = true;

        const data = {
            role: document.querySelector('input[name="role"]:checked').value,
            name: document.getElementById('name').value,
            email: document.getElementById('email').value,
            company: document.getElementById('company').value || 'Individual Creator',
        };

        try {
            // FIXED: Using your provided ID xqenajbz
            const res = await fetch('https://formspree.io/f/xqenajbz', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify(data)
            });
            
            if (res.ok) {
                form.classList.add('hidden');
                document.getElementById('thank-you').classList.remove('hidden');
            } else {
                throw new Error();
            }
        } catch {
            btn.textContent = 'Error - Please try again';
            btn.disabled = false;
        }
    });
</script>

</body>
</html>
